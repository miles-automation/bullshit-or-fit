SPARK_SWARM_API_URL=https://sparkswarm.com/api/v1
SPARK_SLUG=bullshit-or-fit
CORS_ORIGINS=https://bullshitorfit.com,https://www.bullshitorfit.com

# jobtrends data engine (Postgres). Only the ingest worker + CLI use this; the
# web app never opens a connection. Defaults to a local Postgres for `make jobtrends-*`.
DATABASE_URL=postgresql+psycopg://bullshit_or_fit:bullshit_or_fit@localhost:5432/bullshit_or_fit_db
